RewriteEngine On
RewriteBase /Projet_R4.01/

# 1. Allow direct access to physical FILES (css, js, images)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Redirect everything else to index.php
# This ignores physical directories so your PHP can handle the routing
RewriteRule ^ index.php [QSA,L]